# Database
POSTGRES_DB=freelingo
POSTGRES_USER=freelingo
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

# Data persistence path (bind mounts for postgres and redis)
DATA_PATH=/opt/docker/freelingo

# Redis
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# Auth (generate with: openssl rand -hex 32)
SECRET_KEY=CHANGE_ME_SECRET_KEY

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=["http://localhost:3000"]

# Set to true only if serving over HTTPS
COOKIE_SECURE=false

# Registration
ALLOW_REGISTRATION=true
FIRST_USER_IS_ADMIN=true

# LLM (ollama, openai, anthropic, deepseek)
LLM_PROVIDER=ollama

# Ollama (if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma3:12b

# OpenAI (if LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano

# Anthropic (if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-4-5-haiku

# DeepSeek (if LLM_PROVIDER=deepseek)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# TTS — set TTS_PROVIDER=local (Kokoro) or openai
# Local: requires the kokoro service running in docker-compose
# OpenAI: uses OPENAI_API_KEY above, no local service needed
TTS_PROVIDER=local
TTS_BASE_URL=http://kokoro:8880
TTS_VOICE=af_heart
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova

# STT — set STT_PROVIDER=local (faster-whisper) or openai
# Local: requires the whisper service running in docker-compose
# OpenAI: uses OPENAI_API_KEY above, no local service needed
STT_PROVIDER=local
STT_BASE_URL=http://whisper:9000
STT_MODEL=large-v3-turbo
STT_ENGINE=faster_whisper
OPENAI_STT_MODEL=whisper-1

# Logging
# Levels: DEBUG, INFO, WARNING, ERROR. INFO is the recommended default.
# Use DEBUG to see individual audio chunk sizes and TTS bytes (verbose).
LOG_LEVEL=INFO