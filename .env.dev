# Database
POSTGRES_DB=freelingo
POSTGRES_USER=freelingo
POSTGRES_PASSWORD=

# Data persistence path (bind mounts for postgres and redis)
DATA_PATH=./data

# Redis
REDIS_PASSWORD=

# Auth (generate with: openssl rand -hex 32)
SECRET_KEY=

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=["http://localhost:3000"]

# Set to true only if serving over HTTPS
COOKIE_SECURE=false

# Email / SMTP
# Set EMAIL_ENABLED=true and configure SMTP to send verification and reset emails.
# Works with any SMTP provider: Gmail (app password), Brevo, Resend, Google Workspace, etc.
EMAIL_ENABLED=false
# Destination address for the in-app contact form submissions
CONTACT_EMAIL=your@email.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@freelingo.app
SMTP_TLS=true
SMTP_SSL=false
# Public base URL used in email links (no trailing slash)
APP_BASE_URL=https://custom-domain.com

# Registration
ALLOW_REGISTRATION=true
FIRST_USER_IS_ADMIN=true
# Comma-separated list of blocked email domains (e.g. disposable/temporary email providers)
BLOCKED_EMAIL_DOMAINS=["yopmail.com","mailinator.com","guerrillamail.com","temp-mail.org","throwaway.email","trashmail.com"]

# LLM (ollama, openai, anthropic, deepseek)
LLM_PROVIDER=openai

# Ollama (if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma4:e4b

# OpenAI (if LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano

# Anthropic (if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-4-5-haiku

# DeepSeek (if LLM_PROVIDER=deepseek)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# TTS — set TTS_PROVIDER=local (Kokoro) or openai
# Local: requires the kokoro service running in docker-compose
# OpenAI: uses OPENAI_API_KEY above, no local service needed
TTS_PROVIDER=openai
TTS_BASE_URL=http://kokoro:8880
TTS_VOICE=af_heart
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova
OPENAI_TTS_SPEED=1.0

# STT — set STT_PROVIDER=local (faster-whisper) or openai
# Local: requires the whisper service running in docker-compose
# OpenAI: uses OPENAI_API_KEY above, no local service needed
STT_PROVIDER=openai
STT_BASE_URL=http://whisper:9000
STT_MODEL=large-v3-turbo
STT_ENGINE=faster_whisper
OPENAI_STT_MODEL=whisper-1

# Logging
# Levels: DEBUG, INFO, WARNING, ERROR. INFO is the recommended default.
# Use DEBUG to see individual audio chunk sizes and TTS bytes (verbose).
LOG_LEVEL=INFO

# Uvicorn worker processes
# Rule of thumb: 2 × CPU cores + 1. On a 2-core VPS set 5, on a 4-core set 9.
# Keep at 1 for local development or low-resource machines.
UVICORN_WORKERS=1

# Multi-language — comma-separated list of BCP-47 codes the operator wants to offer.
# This is a subset of the languages the system has curriculum data for ("de-DE", "en-US", "en-GB",
# "es-ES", "fr-FR", "it-IT", "pt-PT"). Languages not present in the curriculum are silently ignored.
AVAILABLE_TARGET_LANGUAGES=["en-US","en-GB"]

# Stripe (It isn't necessary to set these for local development or self-hosted deployments, only if you want to enable the subscription paywall in production)
# Set STRIPE_ENABLED=true to activate the subscription paywall.
# When false (default), all billing features are hidden and no paywall is shown.
# Self-hosted deployments should leave this false.
STRIPE_ENABLED=false

# Stripe secret key — use sk_test_... for development, sk_live_... for production
STRIPE_SECRET_KEY=

# Webhook signing secret (whsec_...) — from Stripe Dashboard → Webhooks
STRIPE_WEBHOOK_SECRET=

# Price IDs from Stripe Dashboard → Product catalog
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=

# Trial period in days. Set to 0 to disable trial.
STRIPE_TRIAL_DAYS=7

# Public base URL used in Stripe return URLs (no trailing slash)
# Must match the domain configured in Stripe Dashboard → Webhooks
STRIPE_BASE_URL=https://custom-domain.com

# Optional: set custom price IDs for monthly and yearly subscriptions if you want to use your own Stripe products and prices. If not set, the system will create default products and prices in Stripe on startup.

PRICE_MONTHLY=14.95
PRICE_YEARLY=149.50
TOTAL_PRICE_MONTHLY=19.95
TOTAL_PRICE_YEARLY=199.50

# Umami Analytics (self-hosted, privacy-friendly)
NEXT_PUBLIC_UMAMI_SCRIPT_URL=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=